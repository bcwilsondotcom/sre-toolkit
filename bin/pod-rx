#!/usr/bin/env bash
# pod-rx — Interactive pod diagnosis and prescription engine
# Point at a sick pod, get a diagnosis and actionable fix.
# Usage: pod-rx <pod> [-n ns] | pod-rx --worst [-n ns] | pod-rx --watch [-n ns]
set -euo pipefail

VERSION="1.0.0"
RED='\033[0;31m'; YELLOW='\033[1;33m'; GREEN='\033[0;32m'; CYAN='\033[0;36m'; BOLD='\033[1m'; DIM='\033[2m'; NC='\033[0m'

POD=""
NAMESPACE=""
NS_FLAG=""
WORST_MODE=false
WATCH_MODE=false

usage() {
  cat <<EOF
pod-rx v${VERSION} — Pod diagnosis & prescription

Usage:
  pod-rx <pod-name> [-n namespace]
  pod-rx --worst [-n namespace]     Find and diagnose the most broken pod
  pod-rx --watch [-n namespace]     Continuous monitoring (Ctrl+C to stop)

Options:
  -n, --namespace <ns>   Target namespace
  --worst                Auto-find the sickest pod
  --watch                Continuous scan every 10s
  -h, --help             Show this help

What it does:
  1. Reads pod status, events, and logs
  2. Identifies the root cause
  3. Prescribes specific fix commands you can copy-paste
EOF
  exit 0
}

while [[ $# -gt 0 ]]; do
  case $1 in
    -n|--namespace) NAMESPACE="$2"; NS_FLAG="-n $2"; shift 2 ;;
    --worst) WORST_MODE=true; shift ;;
    --watch) WATCH_MODE=true; shift ;;
    -h|--help) usage ;;
    -*) echo "Unknown: $1"; usage ;;
    *) POD="$1"; shift ;;
  esac
done

header()   { echo -e "\n${CYAN}${BOLD}$1${NC}"; }
symptom()  { echo -e "  ${RED}⚕${NC} Symptom: $1"; }
diagnosis(){ echo -e "  ${YELLOW}🔍${NC} Diagnosis: $1"; }
rx()       { echo -e "  ${GREEN}💊${NC} Rx: ${BOLD}$1${NC}"; }
rx_cmd()   { echo -e "     ${DIM}\$ $1${NC}"; }
info()     { echo -e "  ${DIM}→${NC} $1"; }

find_worst() {
  local worst=""
  local worst_score=0

  while IFS= read -r line; do
    [[ -z "$line" ]] && continue
    pod_name=$(echo "$line" | awk '{print $1}')
    status=$(echo "$line" | awk '{print $3}')
    restarts=$(echo "$line" | awk '{print $4}' | sed 's/[^0-9].*//')

    score=0
    case "$status" in
      CrashLoopBackOff) score=100 ;;
      Error|Init:Error) score=90 ;;
      ImagePullBackOff|ErrImagePull) score=80 ;;
      Pending) score=70 ;;
      OOMKilled) score=95 ;;
      Running)
        if [[ -n "$restarts" ]] && [[ "$restarts" -gt 5 ]]; then
          score=$((restarts))
        fi
        ;;
    esac

    if [[ $score -gt $worst_score ]]; then
      worst_score=$score
      worst="$pod_name"
    fi
  done < <(kubectl get pods $NS_FLAG --no-headers 2>/dev/null)

  if [[ -z "$worst" ]]; then
    echo ""
    return 0
  fi
  echo "$worst"
}

diagnose_pod() {
  local target="$1"

  echo -e "${BOLD}pod-rx v${VERSION}${NC} — diagnosing ${BOLD}$target${NC}"
  echo -e "${DIM}$(date '+%Y-%m-%d %H:%M:%S %Z')${NC}"

  # Get pod info
  local pod_json
  pod_json=$(kubectl get pod "$target" $NS_FLAG -o json 2>/dev/null || echo "")
  if [[ -z "$pod_json" ]]; then
    echo -e "${RED}Pod '$target' not found${NC}"
    return 1
  fi

  local status phase restarts ready
  status=$(echo "$pod_json" | python3 -c "import sys,json; d=json.load(sys.stdin); cs=d.get('status',{}).get('containerStatuses',[]); print(cs[0]['state'] if cs else d['status'].get('phase','Unknown'))" 2>/dev/null || echo "unknown")
  phase=$(echo "$pod_json" | python3 -c "import sys,json; print(json.load(sys.stdin)['status']['phase'])" 2>/dev/null || echo "Unknown")
  restarts=$(echo "$pod_json" | python3 -c "import sys,json; cs=json.load(sys.stdin).get('status',{}).get('containerStatuses',[]); print(cs[0].get('restartCount',0) if cs else 0)" 2>/dev/null || echo "0")
  ready=$(kubectl get pod "$target" $NS_FLAG --no-headers 2>/dev/null | awk '{print $2}')

  local image
  image=$(echo "$pod_json" | python3 -c "import sys,json; print(json.load(sys.stdin)['spec']['containers'][0]['image'])" 2>/dev/null || echo "unknown")

  header "📋 Patient Chart"
  echo -e "  Pod:      ${BOLD}$target${NC}"
  echo -e "  Phase:    $phase"
  echo -e "  Ready:    $ready"
  echo -e "  Restarts: $restarts"
  echo -e "  Image:    $image"

  # Determine the actual status string
  local status_str
  status_str=$(kubectl get pod "$target" $NS_FLAG --no-headers 2>/dev/null | awk '{print $3}')

  header "🩺 Examination"

  # ── CrashLoopBackOff ──
  if [[ "$status_str" == "CrashLoopBackOff" ]]; then
    symptom "CrashLoopBackOff — container starts then immediately crashes, k8s keeps retrying"

    local last_reason last_exit last_log
    last_reason=$(echo "$pod_json" | python3 -c "
import sys,json
cs=json.load(sys.stdin)['status'].get('containerStatuses',[{}])[0]
ls=cs.get('lastState',{}).get('terminated',{})
print(ls.get('reason','Unknown'))
" 2>/dev/null || echo "Unknown")
    last_exit=$(echo "$pod_json" | python3 -c "
import sys,json
cs=json.load(sys.stdin)['status'].get('containerStatuses',[{}])[0]
ls=cs.get('lastState',{}).get('terminated',{})
print(ls.get('exitCode','?'))
" 2>/dev/null || echo "?")

    info "Last termination: $last_reason (exit code: $last_exit)"

    echo -e "\n  ${DIM}Last 15 log lines:${NC}"
    kubectl logs "$target" $NS_FLAG --previous --tail=15 2>/dev/null | while IFS= read -r l; do
      echo -e "  ${DIM}│${NC} $l"
    done

    if [[ "$last_reason" == "OOMKilled" ]]; then
      diagnosis "Out of Memory — container exceeded its memory limit"
      rx "Increase memory limit in deployment spec"
      rx_cmd "kubectl edit deployment \$(kubectl get pod $target $NS_FLAG -o jsonpath='{.metadata.ownerReferences[0].name}') $NS_FLAG"
      rx_cmd "# Under resources.limits.memory — increase the value"
    elif [[ "$last_exit" == "1" ]]; then
      diagnosis "Application error (exit 1) — likely a code bug, missing config, or failed dependency"
      rx "Check the logs above for the actual error message"
      rx_cmd "kubectl logs $target $NS_FLAG --previous | tail -30"
      rx "Common causes: wrong DB host, missing env var, import error, syntax error"
      rx_cmd "kubectl get deployment \$(kubectl get pod $target $NS_FLAG -o jsonpath='{.metadata.ownerReferences[0].name}') $NS_FLAG -o yaml | grep -A20 env"
    elif [[ "$last_exit" == "137" ]]; then
      diagnosis "SIGKILL (exit 137) — killed by OOM killer or liveness probe"
      rx "Check memory limits and liveness probe configuration"
      rx_cmd "kubectl describe pod $target $NS_FLAG | grep -A5 Liveness"
    else
      diagnosis "Container crashing with exit code $last_exit"
      rx "Read the logs carefully — the error is almost always in the last few lines"
      rx_cmd "kubectl logs $target $NS_FLAG --previous"
    fi

  # ── ImagePullBackOff ──
  elif [[ "$status_str" =~ ImagePull ]]; then
    symptom "ImagePullBackOff — Kubernetes can't download the container image"
    info "Image: $image"

    diagnosis "Either the image doesn't exist, the tag is wrong, or registry auth is missing"
    rx "1. Verify the image exists:"
    rx_cmd "docker pull $image"
    rx "2. Check if it's a typo in the deployment:"
    rx_cmd "kubectl get deployment -o yaml $NS_FLAG | grep image:"
    rx "3. If private registry, check imagePullSecrets:"
    rx_cmd "kubectl get pod $target $NS_FLAG -o jsonpath='{.spec.imagePullSecrets}'"
    rx "4. If using kind/minikube, load the image:"
    rx_cmd "kind load docker-image $image  # for kind"
    rx_cmd "eval \$(minikube docker-env)    # for minikube, then rebuild"

  # ── Pending ──
  elif [[ "$status_str" == "Pending" ]]; then
    symptom "Pending — pod can't be scheduled to any node"

    echo -e "\n  ${DIM}Events:${NC}"
    kubectl describe pod "$target" $NS_FLAG 2>/dev/null | sed -n '/Events:/,$p' | tail -10 | while IFS= read -r l; do
      echo -e "  ${DIM}│${NC} $l"
    done

    diagnosis "Scheduler can't find a suitable node — check resource requests, node selectors, taints"
    rx "Check what the scheduler is complaining about:"
    rx_cmd "kubectl describe pod $target $NS_FLAG | grep -A20 Events"
    rx "Common fixes:"
    rx_cmd "# Reduce resource requests if nodes are full"
    rx_cmd "# Remove nodeSelector/affinity if too restrictive"
    rx_cmd "# Add tolerations if nodes are tainted"

  # ── Running but not Ready ──
  elif [[ "$status_str" == "Running" ]] && [[ "$ready" =~ 0/ ]]; then
    symptom "Running but not Ready — container is up but failing health checks"

    diagnosis "Readiness probe is failing — app may be starting slowly or listening on wrong port"
    rx "Check the readiness probe:"
    rx_cmd "kubectl describe pod $target $NS_FLAG | grep -A10 Readiness"
    rx "Check what port the app is actually listening on:"
    rx_cmd "kubectl exec $target $NS_FLAG -- ss -tlnp 2>/dev/null || kubectl exec $target $NS_FLAG -- netstat -tlnp"
    rx "Check recent logs for startup errors:"
    rx_cmd "kubectl logs $target $NS_FLAG --tail=20"

  # ── Running with high restarts ──
  elif [[ "$status_str" == "Running" ]] && [[ "$restarts" -gt 3 ]]; then
    symptom "Running now, but $restarts restarts — intermittent crashes"

    echo -e "\n  ${DIM}Recent logs:${NC}"
    kubectl logs "$target" $NS_FLAG --tail=10 2>/dev/null | while IFS= read -r l; do
      echo -e "  ${DIM}│${NC} $l"
    done

    diagnosis "Pod keeps crashing and recovering — likely a resource issue, dependency timeout, or race condition"
    rx "Check previous crash logs:"
    rx_cmd "kubectl logs $target $NS_FLAG --previous --tail=30"
    rx "Check resource usage:"
    rx_cmd "kubectl top pod $target $NS_FLAG"
    rx "Watch for patterns in events:"
    rx_cmd "kubectl get events $NS_FLAG --sort-by='.lastTimestamp' | grep $target"

  # ── Healthy ──
  elif [[ "$status_str" == "Running" ]]; then
    header "✅ Prognosis"
    echo -e "  ${GREEN}Pod is healthy — Running, Ready ($ready), $restarts restarts${NC}"
    echo -e "  ${DIM}No treatment needed.${NC}"
    return 0

  # ── Other ──
  else
    symptom "Status: $status_str (unusual)"
    diagnosis "Uncommon state — inspect events and logs"
    rx_cmd "kubectl describe pod $target $NS_FLAG"
    rx_cmd "kubectl logs $target $NS_FLAG"
  fi

  # ── Always show helpful context ──
  header "📎 Quick Reference"
  echo -e "  ${DIM}Full describe:${NC}  kubectl describe pod $target $NS_FLAG"
  echo -e "  ${DIM}All logs:${NC}       kubectl logs $target $NS_FLAG"
  echo -e "  ${DIM}Prev logs:${NC}      kubectl logs $target $NS_FLAG --previous"
  echo -e "  ${DIM}Shell in:${NC}       kubectl exec -it $target $NS_FLAG -- /bin/sh"
  echo -e "  ${DIM}Events:${NC}         kubectl get events $NS_FLAG --sort-by='.lastTimestamp'"

  # Get owner deployment for rebuild/redeploy
  local owner
  owner=$(echo "$pod_json" | python3 -c "
import sys,json
refs=json.load(sys.stdin)['metadata'].get('ownerReferences',[])
rs=[r for r in refs if r['kind']=='ReplicaSet']
print(rs[0]['name'].rsplit('-',1)[0] if rs else '')
" 2>/dev/null || echo "")

  if [[ -n "$owner" ]]; then
    echo -e "\n  ${DIM}Parent deploy:${NC}  kubectl get deployment $owner $NS_FLAG -o yaml"
    echo -e "  ${DIM}Redeploy:${NC}       kubectl rollout restart deployment/$owner $NS_FLAG"
    echo -e "  ${DIM}Rollback:${NC}       kubectl rollout undo deployment/$owner $NS_FLAG"
  fi
}

# ── Watch Mode ──
if $WATCH_MODE; then
  echo -e "${BOLD}pod-rx v${VERSION}${NC} — watch mode (Ctrl+C to stop)"
  while true; do
    clear
    TARGET=$(find_worst)
    if [[ "$TARGET" == "All pods"* ]]; then
      echo -e "${GREEN}$(date '+%H:%M:%S')${NC} — All pods healthy"
    else
      diagnose_pod "$TARGET"
    fi
    sleep 10
  done
fi

# ── Worst Mode ──
if $WORST_MODE; then
  POD=$(find_worst 2>/dev/null || echo "")
  if [[ -z "$POD" ]] || [[ "$POD" == "All pods"* ]]; then
    echo -e "${GREEN}All pods look healthy — nothing to diagnose.${NC}"
    exit 0
  fi
fi

[[ -z "$POD" ]] && { echo "Error: pod name required (or use --worst)"; usage; }

diagnose_pod "$POD"
