#!/usr/bin/env bash
# py-diagnose — Find common bugs in Python web apps (Django, Flask, FastAPI)
# Scans for syntax errors, import issues, config problems, DB connection bugs.
# Usage: py-diagnose [path] [--deep]
set -euo pipefail

VERSION="1.0.0"
RED='\033[0;31m'; YELLOW='\033[1;33m'; GREEN='\033[0;32m'; CYAN='\033[0;36m'; BOLD='\033[1m'; DIM='\033[2m'; NC='\033[0m'

TARGET="."
DEEP=false
ISSUES=0
WARNINGS=0

usage() {
  cat <<EOF
py-diagnose v${VERSION} — Python web app diagnostic

Usage: py-diagnose [path] [options]

Options:
  --deep    Run deeper checks (attempt imports, test DB connection)
  -h        Show this help

Scans for:
  • Python syntax errors (compile-time)
  • Missing/broken imports
  • Django: settings misconfig, ALLOWED_HOSTS, DB settings, missing migrations
  • Flask: app factory issues, config problems
  • General: wrong ports, missing env vars, requirements gaps, file permissions

Examples:
  py-diagnose /app
  py-diagnose /srv/webapp --deep
  py-diagnose .
EOF
  exit 0
}

while [[ $# -gt 0 ]]; do
  case $1 in
    --deep) DEEP=true; shift ;;
    -h|--help) usage ;;
    -*) echo "Unknown: $1"; usage ;;
    *) TARGET="$1"; shift ;;
  esac
done

[[ ! -d "$TARGET" ]] && { echo "Error: Directory not found: $TARGET"; exit 2; }

header() { echo -e "\n${CYAN}${BOLD}━━━ $1 ━━━${NC}"; }
ok()     { echo -e "  ${GREEN}✓${NC} $1"; }
warn()   { echo -e "  ${YELLOW}⚠${NC} $1"; ((WARNINGS++)) || true; }
crit()   { echo -e "  ${RED}✗${NC} $1"; ((ISSUES++)) || true; }
fix()    { echo -e "    ${DIM}→ Fix: $1${NC}"; }
info()   { echo -e "  ${DIM}→${NC} $1"; }

PY_FILES=$(find "$TARGET" -name '*.py' -not -path '*/venv/*' -not -path '*/.venv/*' -not -path '*/node_modules/*' -not -path '*/__pycache__/*' 2>/dev/null || echo "")
PY_COUNT=$(echo "$PY_FILES" | grep -c . 2>/dev/null || echo 0)

echo -e "${BOLD}py-diagnose v${VERSION}${NC} — scanning ${BOLD}$TARGET${NC}"
echo -e "${DIM}Found $PY_COUNT Python files${NC}"

# ═══════════════════════════════════════
# 1. SYNTAX CHECK — catches indentation, typos, missing colons
# ═══════════════════════════════════════
header "Syntax Check"
SYNTAX_ERRORS=0
if [[ -n "$PY_FILES" ]]; then
  while IFS= read -r pyfile; do
    [[ -z "$pyfile" ]] && continue
    result=$(python3 -c "
import py_compile, sys
try:
    py_compile.compile('$pyfile', doraise=True)
except py_compile.PyCompileError as e:
    print(str(e))
" 2>&1 || true)
    if [[ -n "$result" ]]; then
      crit "Syntax error in ${BOLD}$pyfile${NC}"
      echo -e "    ${RED}$result${NC}"
      ((SYNTAX_ERRORS++)) || true
    fi
  done <<< "$PY_FILES"

  if [[ $SYNTAX_ERRORS -eq 0 ]]; then
    ok "All $PY_COUNT files compile cleanly"
  fi
else
  warn "No Python files found in $TARGET"
fi

# ═══════════════════════════════════════
# 2. IMPORT CHECK — find broken imports before runtime
# ═══════════════════════════════════════
header "Import Analysis"
if [[ -n "$PY_FILES" ]]; then
  # Collect all imports
  ALL_IMPORTS=$(grep -rh '^\s*import \|^\s*from .* import ' "$TARGET" \
    --include='*.py' \
    --exclude-dir=venv --exclude-dir=.venv --exclude-dir=__pycache__ \
    2>/dev/null | sort -u || echo "")

  # Check for common problematic imports
  IMPORT_ISSUES=0
  while IFS= read -r imp; do
    [[ -z "$imp" ]] && continue
    # Extract module name
    mod=$(echo "$imp" | sed 's/^\s*import \(\S*\).*/\1/' | sed 's/^\s*from \(\S*\) import.*/\1/' | cut -d. -f1)
    [[ -z "$mod" ]] && continue

    # Skip stdlib and relative imports
    if [[ "$mod" == "." ]] || [[ "$mod" == ".." ]]; then continue; fi

    # Try to import it
    if $DEEP; then
      if ! python3 -c "import $mod" 2>/dev/null; then
        # Check if it's in requirements
        if [[ -f "$TARGET/requirements.txt" ]]; then
          if ! grep -qi "$mod" "$TARGET/requirements.txt" 2>/dev/null; then
            crit "Import '$mod' fails and not in requirements.txt"
            fix "pip install $mod && echo '$mod' >> requirements.txt"
            ((IMPORT_ISSUES++)) || true
          else
            warn "Import '$mod' listed in requirements.txt but not installed"
            fix "pip install -r requirements.txt"
            ((IMPORT_ISSUES++)) || true
          fi
        else
          warn "Import '$mod' not available (no requirements.txt to check)"
        fi
      fi
    fi
  done <<< "$ALL_IMPORTS"

  # Check requirements.txt exists
  if [[ -f "$TARGET/requirements.txt" ]]; then
    REQ_COUNT=$(grep -c . "$TARGET/requirements.txt" 2>/dev/null || echo 0)
    ok "requirements.txt found ($REQ_COUNT packages)"
  elif [[ -f "$TARGET/setup.py" ]] || [[ -f "$TARGET/pyproject.toml" ]]; then
    ok "Package config found (setup.py/pyproject.toml)"
  else
    warn "No requirements.txt, setup.py, or pyproject.toml found"
    fix "Create requirements.txt: pip freeze > requirements.txt"
  fi

  if $DEEP && [[ $IMPORT_ISSUES -eq 0 ]]; then
    ok "All imports resolve"
  elif ! $DEEP; then
    info "Use --deep to test actual imports"
  fi
fi

# ═══════════════════════════════════════
# 3. FRAMEWORK DETECTION & CONFIG CHECK
# ═══════════════════════════════════════
header "Framework Detection"

FRAMEWORK="unknown"

# Django detection
if grep -rq 'django\|DJANGO_SETTINGS_MODULE\|from django' "$TARGET" --include='*.py' 2>/dev/null; then
  FRAMEWORK="django"
  MANAGE_PY=$(find "$TARGET" -name 'manage.py' -maxdepth 3 2>/dev/null | head -1)
  SETTINGS=$(find "$TARGET" -name 'settings.py' -not -path '*/venv/*' 2>/dev/null | head -1)
  WSGI=$(find "$TARGET" -name 'wsgi.py' -not -path '*/venv/*' 2>/dev/null | head -1)

  echo -e "  ${BOLD}Django${NC} project detected"
  [[ -n "$MANAGE_PY" ]] && info "manage.py: $MANAGE_PY" || warn "manage.py not found"
  [[ -n "$SETTINGS" ]] && info "settings.py: $SETTINGS" || warn "settings.py not found"

  if [[ -n "$SETTINGS" ]]; then
    echo ""

    # ALLOWED_HOSTS
    AH=$(grep -n 'ALLOWED_HOSTS' "$SETTINGS" 2>/dev/null || echo "")
    if [[ -n "$AH" ]]; then
      if echo "$AH" | grep -q '\[\]'; then
        crit "ALLOWED_HOSTS is empty [] — Django will return 400 for all requests"
        fix "Set ALLOWED_HOSTS = ['*'] for testing, or specific hostname for production"
      elif echo "$AH" | grep -q '\*'; then
        ok "ALLOWED_HOSTS includes wildcard (permissive)"
      else
        ok "ALLOWED_HOSTS configured: $(echo "$AH" | head -1 | cut -d: -f2-)"
      fi
    else
      warn "ALLOWED_HOSTS not found in settings — may cause 400 errors"
      fix "Add: ALLOWED_HOSTS = ['*']"
    fi

    # DEBUG setting
    DEBUG_LINE=$(grep -n '^\s*DEBUG\s*=' "$SETTINGS" 2>/dev/null | head -1 || echo "")
    if [[ -n "$DEBUG_LINE" ]]; then
      if echo "$DEBUG_LINE" | grep -qi 'false'; then
        info "DEBUG = False (production mode — errors won't show in browser)"
      else
        info "DEBUG = True (development mode — detailed errors in browser)"
      fi
    fi

    # DATABASE config
    echo ""
    DB_SECTION=$(grep -A 20 "DATABASES" "$SETTINGS" 2>/dev/null || echo "")
    if [[ -n "$DB_SECTION" ]]; then
      ok "DATABASES config found"

      # Check for common DB issues
      DB_ENGINE=$(echo "$DB_SECTION" | grep -i "ENGINE" | head -1 || echo "")
      DB_NAME_LINE=$(echo "$DB_SECTION" | grep -i "'NAME'" | head -1 || echo "")
      DB_HOST_LINE=$(echo "$DB_SECTION" | grep -i "'HOST'" | head -1 || echo "")
      DB_PORT_LINE=$(echo "$DB_SECTION" | grep -i "'PORT'" | head -1 || echo "")
      DB_USER_LINE=$(echo "$DB_SECTION" | grep -i "'USER'" | head -1 || echo "")
      DB_PASS_LINE=$(echo "$DB_SECTION" | grep -i "'PASSWORD'" | head -1 || echo "")

      [[ -n "$DB_ENGINE" ]] && info "Engine: $(echo "$DB_ENGINE" | sed "s/.*'\(.*\)'.*/\1/")"
      [[ -n "$DB_HOST_LINE" ]] && info "Host: $(echo "$DB_HOST_LINE" | sed "s/.*'\(.*\)'.*/\1/")"
      [[ -n "$DB_PORT_LINE" ]] && info "Port: $(echo "$DB_PORT_LINE" | sed "s/.*'\(.*\)'.*/\1/")"
      [[ -n "$DB_NAME_LINE" ]] && info "DB Name: $(echo "$DB_NAME_LINE" | sed "s/.*'\(.*\)'.*/\1/")"

      if [[ -z "$DB_HOST_LINE" ]] || echo "$DB_HOST_LINE" | grep -q "''"; then
        warn "DB HOST is empty — defaults to localhost socket, may fail in container"
        fix "Set 'HOST': 'localhost' or the actual DB hostname"
      fi

      if [[ -z "$DB_PORT_LINE" ]] || echo "$DB_PORT_LINE" | grep -q "''"; then
        warn "DB PORT is empty — using default (5432 for postgres)"
      fi

      if echo "$DB_PASS_LINE" | grep -qi "password\|123\|secret\|changeme"; then
        warn "DB password looks like a placeholder — verify it's correct"
      fi

      # Check for env var usage (good practice)
      if echo "$DB_SECTION" | grep -q 'os.environ\|os.getenv'; then
        ok "DB config uses environment variables"
      fi
    else
      crit "No DATABASES configuration found in settings"
      fix "Add DATABASES dict — Django can't run without it"
    fi

    # SECRET_KEY
    SK=$(grep 'SECRET_KEY' "$SETTINGS" 2>/dev/null || echo "")
    if [[ -z "$SK" ]]; then
      warn "SECRET_KEY not found"
    fi

    # INSTALLED_APPS check
    echo ""
    if grep -q 'INSTALLED_APPS' "$SETTINGS" 2>/dev/null; then
      ok "INSTALLED_APPS configured"
    fi
  fi

  # Check for migration issues
  if [[ -n "$MANAGE_PY" ]] && $DEEP; then
    echo ""
    info "Checking migrations..."
    MIGRATION_CHECK=$(python3 "$MANAGE_PY" showmigrations 2>&1 || echo "MIGRATION_CHECK_FAILED")
    if echo "$MIGRATION_CHECK" | grep -q '\[ \]'; then
      UNAPPLIED=$(echo "$MIGRATION_CHECK" | grep '\[ \]' | wc -l | tr -d ' ')
      warn "$UNAPPLIED unapplied migration(s) — DB tables may be missing"
      fix "python3 $(basename "$MANAGE_PY") migrate"
    elif echo "$MIGRATION_CHECK" | grep -q 'MIGRATION_CHECK_FAILED'; then
      warn "Could not check migrations (app may have startup errors)"
    else
      ok "All migrations applied"
    fi
  fi

# Flask detection
elif grep -rq 'from flask\|import flask\|Flask(__name__)' "$TARGET" --include='*.py' 2>/dev/null; then
  FRAMEWORK="flask"
  echo -e "  ${BOLD}Flask${NC} app detected"

  APP_FILE=$(grep -rl 'Flask(__name__)\|create_app' "$TARGET" --include='*.py' 2>/dev/null | head -1)
  [[ -n "$APP_FILE" ]] && info "App file: $APP_FILE"

  if [[ -n "$APP_FILE" ]]; then
    # Check for port binding
    PORT_LINE=$(grep -n '\.run(' "$APP_FILE" 2>/dev/null || echo "")
    if [[ -n "$PORT_LINE" ]]; then
      info "Server run: $(echo "$PORT_LINE" | head -1 | cut -d: -f2-)"
      if echo "$PORT_LINE" | grep -q 'host='; then
        if echo "$PORT_LINE" | grep -q "0.0.0.0"; then
          ok "Listening on 0.0.0.0 (accessible from outside container)"
        elif echo "$PORT_LINE" | grep -q "127.0.0.1\|localhost"; then
          crit "Listening on 127.0.0.1 — unreachable from outside the container"
          fix "Change to: app.run(host='0.0.0.0', port=...)"
        fi
      else
        warn "No host= in app.run() — defaults to 127.0.0.1 (unreachable in Docker)"
        fix "Add: app.run(host='0.0.0.0', port=8000)"
      fi
    fi

    # Check for DB config
    if grep -q 'SQLALCHEMY_DATABASE_URI\|DATABASE_URL\|psycopg2\|pg8000' "$APP_FILE" 2>/dev/null; then
      ok "Database configuration found"
      DB_URI=$(grep -h 'DATABASE_URI\|DATABASE_URL' "$APP_FILE" 2>/dev/null | head -1 || echo "")
      [[ -n "$DB_URI" ]] && info "$(echo "$DB_URI" | sed 's/^\s*//')"
    fi
  fi

# FastAPI detection
elif grep -rq 'from fastapi\|import fastapi\|FastAPI()' "$TARGET" --include='*.py' 2>/dev/null; then
  FRAMEWORK="fastapi"
  echo -e "  ${BOLD}FastAPI${NC} app detected"
  APP_FILE=$(grep -rl 'FastAPI()' "$TARGET" --include='*.py' 2>/dev/null | head -1)
  [[ -n "$APP_FILE" ]] && info "App file: $APP_FILE"

else
  info "No Django/Flask/FastAPI detected — running general Python checks"
fi

# ═══════════════════════════════════════
# 4. DOCKERFILE & ENTRYPOINT CHECK
# ═══════════════════════════════════════
header "Docker & Entrypoint"

DOCKERFILE=$(find "$TARGET" -name 'Dockerfile' -maxdepth 3 2>/dev/null | head -1)
COMPOSE=$(find "$TARGET" -name 'docker-compose*' -maxdepth 3 2>/dev/null | head -1)

if [[ -n "$DOCKERFILE" ]]; then
  ok "Dockerfile found: $DOCKERFILE"

  # Check EXPOSE vs app port
  EXPOSED=$(grep '^EXPOSE' "$DOCKERFILE" 2>/dev/null | awk '{print $2}' || echo "")
  CMD_LINE=$(grep '^CMD\|^ENTRYPOINT' "$DOCKERFILE" 2>/dev/null | tail -1 || echo "")

  [[ -n "$EXPOSED" ]] && info "EXPOSE: $EXPOSED"
  [[ -n "$CMD_LINE" ]] && info "Startup: $CMD_LINE"

  # Check if requirements are installed
  if ! grep -q 'pip install\|pip3 install' "$DOCKERFILE" 2>/dev/null; then
    if [[ -f "$TARGET/requirements.txt" ]]; then
      crit "Dockerfile doesn't install requirements.txt"
      fix "Add: RUN pip install --no-cache-dir -r requirements.txt"
    fi
  else
    ok "pip install found in Dockerfile"
  fi

  # Check WORKDIR
  if ! grep -q 'WORKDIR' "$DOCKERFILE" 2>/dev/null; then
    warn "No WORKDIR set — files land in /"
    fix "Add: WORKDIR /app"
  fi

  # Check for COPY of app code
  if ! grep -q 'COPY.*\.py\|COPY \.' "$DOCKERFILE" 2>/dev/null; then
    warn "No COPY of application code visible"
    fix "Add: COPY . ."
  fi
else
  warn "No Dockerfile found in $TARGET"
fi

[[ -n "$COMPOSE" ]] && info "Docker Compose: $COMPOSE"

# ═══════════════════════════════════════
# 5. ENVIRONMENT & CONNECTION CHECK  
# ═══════════════════════════════════════
header "Environment & Connections"

# .env file
if [[ -f "$TARGET/.env" ]]; then
  ok ".env file found"
  # Check for common vars
  for var in DATABASE_URL DB_HOST DB_NAME DB_USER DB_PASSWORD SECRET_KEY; do
    if grep -q "^$var=" "$TARGET/.env" 2>/dev/null; then
      val=$(grep "^$var=" "$TARGET/.env" | cut -d= -f2-)
      if [[ -z "$val" ]] || [[ "$val" == '""' ]] || [[ "$val" == "''" ]]; then
        warn "$var is empty in .env"
      else
        ok "$var is set"
      fi
    fi
  done
fi

# Check if psql is available and DB is reachable
if $DEEP && command -v psql &>/dev/null; then
  # Try to extract DB connection from settings/env
  DB_HOST_VAL=""
  DB_PORT_VAL="5432"
  DB_USER_VAL="postgres"
  DB_NAME_VAL=""

  if [[ -n "${SETTINGS:-}" ]]; then
    DB_HOST_VAL=$(grep "'HOST'" "$SETTINGS" 2>/dev/null | sed "s/.*'\([^']*\)'.*/\1/" | tail -1 || echo "")
    DB_NAME_VAL=$(grep "'NAME'" "$SETTINGS" 2>/dev/null | sed "s/.*'\([^']*\)'.*/\1/" | tail -1 || echo "")
  fi

  if [[ -n "$DB_HOST_VAL" ]] && [[ -n "$DB_NAME_VAL" ]]; then
    if psql -h "$DB_HOST_VAL" -U "$DB_USER_VAL" -d "$DB_NAME_VAL" -c "SELECT 1" &>/dev/null; then
      ok "Database connection successful ($DB_HOST_VAL/$DB_NAME_VAL)"
    else
      crit "Cannot connect to database at $DB_HOST_VAL/$DB_NAME_VAL"
      fix "Check DB host, port, user, password. Test: psql -h $DB_HOST_VAL -U $DB_USER_VAL -d $DB_NAME_VAL"
    fi
  fi
fi

# ═══════════════════════════════════════
# 6. COMMON BUG PATTERNS
# ═══════════════════════════════════════
header "Common Bug Patterns"

if [[ -n "$PY_FILES" ]]; then
  # Indentation mixing (tabs vs spaces)
  MIXED=$(grep -rn '^\t' "$TARGET" --include='*.py' --exclude-dir=venv --exclude-dir=__pycache__ 2>/dev/null | head -3 || echo "")
  if [[ -n "$MIXED" ]]; then
    warn "Tab indentation found (Python prefers spaces):"
    echo "$MIXED" | head -3 | while IFS= read -r line; do
      echo -e "    ${DIM}$line${NC}"
    done
    fix "Convert tabs to spaces: expand -t 4 file.py > file_fixed.py"
  else
    ok "Consistent indentation (no tabs)"
  fi

  # Print statements (Python 2 vs 3)
  PY2_PRINT=$(grep -rn '^\s*print [^(]' "$TARGET" --include='*.py' --exclude-dir=venv --exclude-dir=__pycache__ 2>/dev/null | head -3 || echo "")
  if [[ -n "$PY2_PRINT" ]]; then
    crit "Python 2 print statement (needs parentheses in Python 3):"
    echo "$PY2_PRINT" | head -3 | while IFS= read -r line; do
      echo -e "    ${DIM}$line${NC}"
    done
    fix "Change: print 'x' → print('x')"
  fi

  # Undefined variable patterns (common typos)
  # Look for variables used but not defined in same file
  # This is heuristic, not perfect
  TYPO_CANDIDATES=$(grep -rn 'NameError\|undefined\|is not defined' "$TARGET" --include='*.py' --exclude-dir=venv 2>/dev/null | head -3 || echo "")
  if [[ -n "$TYPO_CANDIDATES" ]]; then
    warn "Possible undefined variable references found"
  fi

  # Missing return in view functions
  if [[ "$FRAMEWORK" == "django" ]]; then
    VIEW_FILES=$(grep -rl 'def .*request' "$TARGET" --include='*.py' --exclude-dir=venv 2>/dev/null || echo "")
    if [[ -n "$VIEW_FILES" ]]; then
      while IFS= read -r vf; do
        [[ -z "$vf" ]] && continue
        # Very basic check: view function without HttpResponse/render/redirect
        VIEWS=$(grep -c 'def .*request' "$vf" 2>/dev/null || echo 0)
        RETURNS=$(grep -c 'HttpResponse\|render\|redirect\|JsonResponse' "$vf" 2>/dev/null || echo 0)
        if [[ "$VIEWS" -gt 0 ]] && [[ "$RETURNS" -eq 0 ]]; then
          warn "$(basename "$vf") has view function(s) but no HttpResponse/render — may return None"
        fi
      done <<< "$VIEW_FILES"
    fi
  fi

  # Wrong port in code vs Dockerfile
  if [[ -n "${EXPOSED:-}" ]] && [[ -n "$PY_FILES" ]]; then
    CODE_PORT=$(grep -rh 'port.*=.*[0-9]\{4\}\|:.*[0-9]\{4\}' "$TARGET" --include='*.py' --exclude-dir=venv 2>/dev/null | grep -oE '[0-9]{4,5}' | sort -u | head -1 || echo "")
    if [[ -n "$CODE_PORT" ]] && [[ -n "$EXPOSED" ]] && [[ "$CODE_PORT" != "$EXPOSED" ]]; then
      crit "Port mismatch: app uses $CODE_PORT but Dockerfile EXPOSE $EXPOSED"
      fix "Match the ports — either change EXPOSE or the app's port"
    fi
  fi
fi

# ═══════════════════════════════════════
# SUMMARY
# ═══════════════════════════════════════
echo ""
echo -e "${BOLD}━━━ Diagnosis Summary ━━━${NC}"
echo -e "  Framework: $FRAMEWORK | Files: $PY_COUNT"
if [[ $ISSUES -eq 0 ]] && [[ $WARNINGS -eq 0 ]]; then
  echo -e "  ${GREEN}${BOLD}✓ No issues found${NC}"
  exit 0
elif [[ $ISSUES -eq 0 ]]; then
  echo -e "  ${YELLOW}${BOLD}⚠ $WARNINGS warning(s)${NC}"
  exit 0
else
  echo -e "  ${RED}${BOLD}✗ $ISSUES critical, $WARNINGS warning(s)${NC}"
  exit 1
fi
